{
  "name": "@scrappr/infra",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "deploy": "cdk deploy --all --require-approval never",
    "deploy:dev": "node scripts/deploy-env.mjs --env dev",
    "deploy:ui": "cdk deploy scrappr-ui-* --require-approval never",
    "destroy:ui": "cdk destroy scrappr-ui-* --force",
    "diff": "cdk diff --all",
    "synth": "cdk synth"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.0.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-ses": "^3.0.0",
    "@aws-sdk/client-sesv2": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@aws-sdk/s3-presigned-post": "^3.0.0",
    "@scrappr/shared": "0.0.1",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.180.0",
    "typescript": "~5.9.3"
  }
}
