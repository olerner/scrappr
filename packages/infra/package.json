{
  "name": "@scrappr/infra",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "deploy": "cdk deploy --all --require-approval never",
    "deploy:ui": "cdk deploy scrappr-ui-* --require-approval never",
