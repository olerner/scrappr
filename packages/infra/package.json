    "diff": "cdk diff --all",
    "synth": "cdk synth"
  },
  "dependencies": {
    "@scrappr/shared": "0.0.1",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.180.0",
    "typescript": "~5.9.3"
  }
}
