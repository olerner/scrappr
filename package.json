{
  "name": "scrappr",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,green \"yarn api\" \"yarn ui\"",
    "api": "nodemon --watch template.yaml --exec 'sam local start-api' --signal SIGTERM --delay 1",
    "ui": "yarn workspace @scrappr/ui dev",
    "deploy": "yarn workspace @scrappr/ui build && yarn workspace @scrappr/infra deploy",
    "deploy:dev": "yarn workspace @scrappr/ui build && yarn workspace @scrappr/infra deploy:dev",
    "infra:diff": "yarn workspace @scrappr/infra diff",
    "lint": "biome check packages/",
    "lint:fix": "biome check --fix packages/",
    "format": "prettier --write '**/*.{json,yaml,yml,md}'",
    "format:check": "prettier --check '**/*.{json,yaml,yml,md}'",
    "check": "biome check packages/ && prettier --check '**/*.{json,yaml,yml,md}'",
    "test": "node --test packages/infra/src/lambdas/*.test.mjs",
    "e2e": "yarn workspace @scrappr/e2e test",
    "e2e:headed": "yarn workspace @scrappr/e2e test:headed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1"
  }
}
